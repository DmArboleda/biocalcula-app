<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F0">

    <!-- Encabezado -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E7D32"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTituloPantalla"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nuevo Registro"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingresa tu peso actual"
            android:textColor="#C8E6C9"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Tarjeta con el formulario -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Peso corporal (kg)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#388E3C"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etPesoIngresado"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ej: 70.5"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="16dp"
                android:textSize="18sp"
                android:textColor="#212121"
                android:textColorHint="#BDBDBD" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Mantén pulsado un registro en la lista para eliminarlo"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnGuardarPeso"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Guardar"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="20dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>

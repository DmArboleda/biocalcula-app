<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Encabezado -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="🌙 Resumen del día"
                android:textColor="@color/color_text_primary"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp"
                android:text="Registra cuánto consumiste hoy para mejorar tu análisis semanal"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp" />

            <!-- ═══════════════ AGUA ═══════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="#40118AB2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Título agua -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💧"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Agua"
                                android:textColor="@color/color_text_primary"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvAguaMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meta: 2.1L = 8 vasos"
                                android:textColor="@color/color_agua"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Toggle L / Vasos -->
                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleAguaUnidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnToggleVasos"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Vasos"
                                android:textSize="11sp"
                                app:strokeColor="@color/color_agua"
                                android:textColor="@color/color_agua" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnToggleLitros"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Litros"
                                android:textSize="11sp"
                                app:strokeColor="@color/color_agua"
                                android:textColor="@color/color_agua" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>

                    <!-- Vasos visuales (íconos) -->
                    <LinearLayout
                        android:id="@+id/layoutVasosIconos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal" />

                    <!-- Slider vasos -->
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderVasos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:valueFrom="0"
                        android:valueTo="16"
                        android:stepSize="1"
                        android:value="0"
                        app:thumbColor="@color/color_agua"
                        app:trackColorActive="@color/color_agua"
                        app:trackColorInactive="#40118AB2"
                        app:labelBehavior="floating" />

                    <!-- Campo litros (oculto por defecto) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutLitros"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        app:boxStrokeColor="@color/color_agua"
                        app:hintTextColor="@color/color_agua"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLitros"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Litros bebidos (ej: 1.5)"
                            android:inputType="numberDecimal"
                            android:textColor="@color/color_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Texto cantidad seleccionada -->
                    <TextView
                        android:id="@+id/tvAguaSeleccionada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="0 vasos (0 ml)"
                        android:textColor="@color/color_agua"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════ PROTEÍNAS ═══════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="#40FF6B6B"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🥩"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Proteínas"
                                android:textColor="@color/color_text_primary"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvProteinaMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meta: --g"
                                android:textColor="@color/color_proteina"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbProteinaCumplida"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cumplí"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="13sp"
                            app:buttonTint="@color/color_proteina" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutProteinaGramos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxStrokeColor="@color/color_proteina"
                        app:hintTextColor="@color/color_proteina"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProteinaGramos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Gramos consumidos (ej: 120)"
                            android:inputType="numberDecimal"
                            android:textColor="@color/color_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════ CARBOHIDRATOS ═══════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="#40FFD166"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌾"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Carbohidratos"
                                android:textColor="@color/color_text_primary"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvCarbosMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meta: --g"
                                android:textColor="@color/color_carbos"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbCarbosCumplidos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cumplí"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="13sp"
                            app:buttonTint="@color/color_carbos" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutCarbosGramos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxStrokeColor="@color/color_carbos"
                        app:hintTextColor="@color/color_carbos"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCarbosGramos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Gramos consumidos (ej: 250)"
                            android:inputType="numberDecimal"
                            android:textColor="@color/color_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════ GRASAS ═══════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="#4006D6A0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🥑"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Grasas"
                                android:textColor="@color/color_text_primary"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvGrasasMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meta: --g"
                                android:textColor="@color/color_grasas"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbGrasasCumplidas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cumplí"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="13sp"
                            app:buttonTint="@color/color_grasas" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutGrasasGramos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxStrokeColor="@color/color_grasas"
                        app:hintTextColor="@color/color_grasas"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etGrasasGramos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Gramos consumidos (ej: 60)"
                            android:inputType="numberDecimal"
                            android:textColor="@color/color_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botón Guardar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarConsumo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="💾  Guardar mi consumo de hoy"
                android:textSize="16sp"
                app:backgroundTint="@color/color_primary"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
